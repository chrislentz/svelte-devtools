{
  "name": "@svelte-devtools/vite-plugin",
  "version": "0.1.4",
  "description": "Vite plugin that adds a development overlay for inspecting Svelte 5 and SvelteKit apps",
  "type": "module",
  "keywords": [
    "svelte",
    "svelte5",
    "sveltekit",
    "devtools",
    "vite",
    "vite-plugin",
    "debug",
    "inspector"
  ],
  "author": "Chris Lentz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrislentz/svelte-devtools.git",
    "directory": "packages/vite-plugin"
  },
  "homepage": "https://github.com/chrislentz/svelte-devtools#readme",
  "bugs": "https://github.com/chrislentz/svelte-devtools/issues",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json && cp ../overlay/dist/overlay.js dist/overlay.js",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.0"
  }
}
