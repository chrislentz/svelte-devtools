{
  "name": "svelte-devtools",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "playground"],
  "repository": {
    "type": "git",
    "url": "https://github.com/chrislentz/svelte-devtools.git"
  },
  "scripts": {
    "setup": "npm install && npm run build:overlay",
    "build:overlay": "npm run build -w @svelte-devtools/overlay",
    "dev:overlay": "npm run dev -w @svelte-devtools/overlay",
    "build:packages": "npm run build -w vite-plugin-svelte-devtools && npm run build -w @svelte-devtools/kit",
    "dev": "npm run dev -w playground",
    "build": "npm run build -w playground"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
