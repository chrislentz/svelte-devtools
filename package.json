{
  "name": "svelte-devtools",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/chrislentz/svelte-devtools.git"
  },
  "scripts": {
    "setup": "pnpm install && pnpm build:overlay",
    "build:overlay": "pnpm --filter @svelte-devtools/overlay build",
    "dev:overlay": "pnpm --filter @svelte-devtools/overlay dev",
    "build:packages": "pnpm --filter vite-plugin-svelte-devtools build && pnpm --filter @svelte-devtools/kit build",
    "dev": "pnpm --filter playground dev",
    "build": "pnpm --filter playground build"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
